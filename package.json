{
  "name": "fusion-trading-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fusion Trading Lab: backtests, pattern recognition, specialist registry, TradingView Pine exports, and dashboard.",
  "scripts": {
    "lab:pattern": "node packages/pattern-lab/pattern_lab.js",
    "lab:dashboard": "node scripts/build_dashboard_data.js",
    "lab:nightly": "node scripts/lab_nightly.js",
    "lab:report": "npm run lab:pattern && npm run lab:dashboard",
    "lab:phase21": "npm run lab:report",
    "scalp:phase22": "node scripts/phase22_deep_specialist_tournament.js",
    "scalp:phase19": "node scripts/phase19_champion_council_fusion.js",
    "scalp:closed-loop:start": "bash scripts/start_live_closed_loop.sh",
    "scalp:closed-loop:stop": "bash scripts/stop_live_closed_loop.sh",
    "scalp:closed-loop:update": "node scripts/phase18_forward_proven_router.js && npm run lab:report",
    "pine:export": "node packages/pine-export/sync_pine_metadata.js",
    "scalp:phase23": "node scripts/phase23_intelligence_specialist_tournament.js",
    "lab:phase24": "node scripts/phase24_self_improvement_loop.js",
    "lab:phase25": "node scripts/phase25_fresh_symbol_tournament.js",
    "lab:phase26": "node scripts/phase26_generalization_engine.js",
    "lab:phase27": "node scripts/phase27_champion_promotion_reality_audit.js",
    "lab:self-improve": "npm run lab:phase24 && npm run options:probe -- --fetch-current=true --provider-symbol-limit=2 && npm run pine:export && npm run lab:dashboard",
    "options:probe": "node scripts/options_data_probe.js",
    "options:actual": "node scripts/options_actual_backtest.js",
    "test": "npm run pine:export && npm run lab:dashboard && node scripts/validate_lab_outputs.js"
  },
  "engines": {
    "node": ">=20"
  }
}
