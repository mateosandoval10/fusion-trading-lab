# Optional: read historical ledgers without copying them into this repo.
# Comma-separated directories. Use this locally; GitHub Actions can use artifacts/backtest output.
FUSION_EXTERNAL_LEDGER_DIRS=/absolute/path/to/old/optimization-results/local-runs,/absolute/path/to/old/optimization-results/trade-ledger

# Optional Pattern Lab caps for memory-safe runs.
FUSION_ALERT_PORT=8787

# Optional exact options backtesting provider.
# Required for `npm run options:actual` to retrieve historical option contracts
# and intraday bid/ask quotes. Keep this local; never commit real keys.
POLYGON_API_KEY=
